# VaayuLens AI — Environment Variables

# Data mode: "synthetic" (default, no API keys needed) or "live" (requires API keys below)
DATA_MODE=synthetic

# MongoDB Atlas connection string (free tier)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vaayulens?retryWrites=true&w=majority

# OpenWeatherMap API key (free tier — only needed if DATA_MODE=live)
OWM_API_KEY=your_openweathermap_api_key_here

# CPCB / data.gov.in API key (only needed if DATA_MODE=live)
CPCB_API_KEY=your_datagov_api_key_here

# Frontend URL for CORS (comma-separated if multiple)
FRONTEND_URLS=http://localhost:5173,https://vaayulens.vercel.app
